generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String?  @unique
  emailVerified DateTime?
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  accounts Account[]
  sessions Session[]

  reviews   Review[]
  favorites Favorite[]

  places    Place[]
}

model Place {
  id          String  @id @default(uuid())
  name        String
  description String?
  address     String

  googlePlaceId String? @unique

  lat Float
  lng Float

  avgRating   Float?
  reviewCount Int @default(0)

  createdAt DateTime @default(now())

  createdById String?
  createdBy   User? @relation(fields: [createdById], references: [id])

  reviews    Review[]
  tags       PlaceTag[]
  facilities PlaceFacility[]
  favorites  Favorite[]
}

model Tag {
  id   String @id @default(uuid())
  name String @unique
  category String?

  places PlaceTag[]
}

model PlaceTag {
  placeId String
  tagId   String

  place Place @relation(fields: [placeId], references: [id])
  tag   Tag   @relation(fields: [tagId], references: [id])

  @@id([placeId, tagId])
}

model Facility {
  id   String @id @default(uuid())
  name String @unique

  places PlaceFacility[]
}

model PlaceFacility {
  placeId    String
  facilityId String

  place    Place    @relation(fields: [placeId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@id([placeId, facilityId])
}

model Review {
  id      String @id @default(uuid())
  userId  String
  placeId String

  serviceScore     Int
  strollerScore    Int
  facilityScore    Int
  cleanlinessScore Int
  transportScore   Int

  comment String?

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  place Place @relation(fields: [placeId], references: [id])

  @@index([placeId])
  @@index([userId])
}

model Favorite {
  userId  String
  placeId String

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  place Place @relation(fields: [placeId], references: [id])

  @@id([userId, placeId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

enum ExternalSourceType {
  GOV_FAMILY_TOILET
  GOV_NURSING_ROOM
  GOV_PARENTING_CENTER
}

model ExternalPlace {
  id           String             @id @default(cuid())
  sourceType   ExternalSourceType
  sourceId     String
  name         String
  address      String?
  lat          Float?
  lng          Float?

  city         String?
  district     String?
  phone        String?
  openTime     String?
  note         String?
  officialUrl  String?

  isActive     Boolean            @default(true)
  rawData      Json?
  lastSyncedAt DateTime           @default(now())

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tags         ExternalPlaceTag[]
  facilities   ExternalPlaceFacility[]

  @@unique([sourceType, sourceId])
  @@index([sourceType])
  @@index([isActive])
  @@index([city, district])
  @@index([lat, lng])
}

model ExternalTag {
  id        String             @id @default(cuid())
  name      String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  places    ExternalPlaceTag[]
}

model ExternalFacility {
  id        String                  @id @default(cuid())
  name      String                  @unique
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  places    ExternalPlaceFacility[]
}

model ExternalPlaceTag {
  externalPlaceId String
  tagId           String

  externalPlace   ExternalPlace @relation(fields: [externalPlaceId], references: [id], onDelete: Cascade)
  tag             ExternalTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([externalPlaceId, tagId])
  @@index([tagId])
}

model ExternalPlaceFacility {
  externalPlaceId String
  facilityId      String

  externalPlace   ExternalPlace    @relation(fields: [externalPlaceId], references: [id], onDelete: Cascade)
  facility        ExternalFacility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([externalPlaceId, facilityId])
  @@index([facilityId])
}